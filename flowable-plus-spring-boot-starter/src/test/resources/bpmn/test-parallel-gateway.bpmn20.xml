<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:activiti="http://activiti.org/bpmn"
             targetNamespace="http://flowable.plus/test">
  <process id="testParallelGateway" name="并行网关审批（集成测试）" isExecutable="true">
    <documentation>用于 TaskExecutionIntegrationTest：completeTask / rejectTask / withdrawTask / transferTask / jumpToNode
    并行分支：部门审批 + 财务审批 → 并行网关汇合 → 排他条件路由 → 终审</documentation>
    <startEvent id="start"/>
    <userTask id="draft" name="发起" activiti:assignee="${initiator}"/>

    <!-- 并行分支 -->
    <parallelGateway id="fork"/>
    <userTask id="branch1" name="部门审批" activiti:assignee="${approver1}"/>
    <userTask id="branch2" name="财务审批" activiti:assignee="${approver2}"/>
    <parallelGateway id="join"/>

    <!-- 排他条件路由 -->
    <exclusiveGateway id="decision" default="f8"/>
    <userTask id="finalTask" name="终审" activiti:assignee="${approver3}"/>
    <endEvent id="end"/>

    <sequenceFlow id="f1" sourceRef="start" targetRef="draft"/>
    <sequenceFlow id="f2" sourceRef="draft" targetRef="fork"/>
    <sequenceFlow id="f3" sourceRef="fork" targetRef="branch1"/>
    <sequenceFlow id="f4" sourceRef="fork" targetRef="branch2"/>
    <sequenceFlow id="f5" sourceRef="branch1" targetRef="join"/>
    <sequenceFlow id="f6" sourceRef="branch2" targetRef="join"/>
    <sequenceFlow id="f7" sourceRef="join" targetRef="decision"/>
    <sequenceFlow id="f8" name="正常" sourceRef="decision" targetRef="finalTask"/>
    <sequenceFlow id="f9" name="跳过终审" sourceRef="decision" targetRef="end">
      <conditionExpression xsi:type="tFormalExpression">${skipFinal == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="f10" sourceRef="finalTask" targetRef="end"/>
  </process>
</definitions>
